pipeline {
    agent any
    environment {
        EMAIL_TO = 'ashmasuneja2006@gmail.com'
    }
    stages {
        stage('Install Dependencies (Node.js & NPM)') {
            steps {
                // Tool: Node.js, NPM
                bat 'npm install'
            }
        }
        stage('Run Tests (Jest/Mocha)') {
            steps {
                // Tool: Jest or Mocha
                bat 'npm test || exit /b 0'
            }
            post {
                always {
                    emailext (
                        to: "${EMAIL_TO}",
                        subject: "Test Stage: ${currentBuild.currentResult}",
                        body: """
                        Test Stage Completed.

                        Status: ${currentBuild.currentResult}
                        Job: ${env.JOB_NAME}
                        Build Number: ${env.BUILD_NUMBER}
                        """,
                        attachLog: true
                    )
                }
            }
        }
        stage('Generate Coverage Report (Istanbul/nyc)') {
            steps {
                // Tool: Istanbul (nyc)
                bat 'npm run coverage || exit /b 0'
            }
        }
        stage('NPM Audit (Security Scan)') {
            steps {
                // Tool: NPM Audit
                bat 'npm audit || exit /b 0'
            }
            post {
                always {
                    emailext (
                        to: "${EMAIL_TO}",
                        subject: "Security Scan Stage: ${currentBuild.currentResult}",
                        body: """
                        Security Scan Completed.

                        Status: ${currentBuild.currentResult}
                        Job: ${env.JOB_NAME}
                        Build Number: ${env.BUILD_NUMBER}
                        """,
                        attachLog: true
                    )
                }
            }
        }
    }
    post {
        always {
            echo 'Pipeline completed successfully'
        }
    }
}
